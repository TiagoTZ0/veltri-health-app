# Example environment variables for local development and for Render secrets.

# -----------------
# Backend (Django)
# -----------------
SECRET_KEY=change_me_in_production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1

# Option A (recommended on Render): single DATABASE_URL
# e.g. postgres://user:pass@host:5432/dbname
DATABASE_URL=

# Option B (alternative): individual DB_* vars used by entrypoint.sh
DATABASE=postgres
DB_HOST=
DB_PORT=5432
DB_USER=
DB_PASSWORD=
DB_NAME=veltri

# Optional email / monitoring
EMAIL_HOST=
EMAIL_PORT=
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
SENTRY_DSN=


# -----------------
# AI service
# -----------------
# Path inside container where models live (default in repo: ai-service/models)
MODELS_DIR=/app/models


# -----------------
# Frontend (Expo)
# -----------------
# URL pública del backend y del ai-service
EXPO_PUBLIC_API_URL=https://veltri-backend.onrender.com
EXPO_PUBLIC_AI_URL=https://veltri-ai-service.onrender.com
